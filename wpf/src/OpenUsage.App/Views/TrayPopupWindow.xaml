<Window x:Class="OpenUsage.App.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OpenUsage.App.Views"
        xmlns:controls="clr-namespace:OpenUsage.App.Views.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="400" Height="550"
        Deactivated="Window_Deactivated"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">

    <Border x:Name="OuterBorder" CornerRadius="12"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderThickness="0"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.4" Color="Black" />
        </Border.Effect>

        <Border CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <controls:SideNavigation x:Name="SideNav"
                                         Grid.Column="0"
                                         Plugins="{Binding Overview.Providers}"
                                         SelectedPage="{Binding CurrentPage, Mode=OneWay}"
                                         SelectedProviderId="{Binding SelectedProviderId, Mode=OneWay}"
                                         NavigateToOverviewCommand="{Binding NavigateToOverviewCommand}"
                                         NavigateToSettingsCommand="{Binding NavigateToSettingsCommand}"
                                         ProviderSelected="SideNav_ProviderSelected"
                                         PinToggled="SideNav_PinToggled" />

                <!-- Content area -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Page content -->
                    <ContentControl Grid.Row="0" Content="{Binding}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Overview">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <views:OverviewPage DataContext="{Binding Overview}" />
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Detail">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <views:ProviderDetailPage DataContext="{Binding ProviderDetail}" />
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <views:SettingsPage DataContext="{Binding Settings}" />
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                    <!-- Footer -->
                    <Border Grid.Row="1" Height="36"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="12,0">
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="OpenUsage v1.0.0" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <!-- Clickable countdown: text shows "Next update in Xs",
                                 clicking triggers a manual refresh of all providers. -->
                            <Button x:Name="NextUpdateButton"
                                    Style="{StaticResource LinkButtonStyle}"
                                    Content="{Binding NextUpdateLabel}"
                                    Command="{Binding Overview.RefreshAllCommand}"
                                    ToolTip="Refresh now"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>
