<UserControl x:Class="OpenUsage.App.Views.Controls.ProviderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OpenUsage.App.Views.Controls"
             DataContextChanged="OnDataContextChanged">

    <Border x:Name="CardBorder" Padding="14,12" Background="Transparent" CornerRadius="8" Margin="4,2">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel>
            <!-- Provider header: icon + name + plan badge -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Provider icon (populated from code-behind) -->
                <Border Grid.Column="0" x:Name="IconContainer"
                        Width="28" Height="28" Margin="0,0,10,0"
                        VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding Meta.Name}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- Plan badge -->
                <Border Grid.Column="2"
                        CornerRadius="10" Padding="10,3"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource TextSecondaryBrush}"
                        Background="Transparent"
                        VerticalAlignment="Center"
                        Visibility="{Binding Data.Plan, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding Data.Plan}"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Border>
            </Grid>

            <!-- Loading skeleton -->
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <Border Background="{DynamicResource ProgressTrackBrush}" CornerRadius="7" Height="14" Margin="0,0,0,8">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.2" To="0.6" Duration="0:0:1.0"
                                                     AutoReverse="True">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
                <Border Background="{DynamicResource ProgressTrackBrush}" CornerRadius="5" Height="10" Margin="0,0,40,8"
                        HorizontalAlignment="Stretch">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.2" To="0.6" Duration="0:0:1.0"
                                                     BeginTime="0:0:0.15"
                                                     AutoReverse="True">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
                <Border Background="{DynamicResource ProgressTrackBrush}" CornerRadius="4" Height="8"
                        Width="100" HorizontalAlignment="Left">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.2" To="0.6" Duration="0:0:1.0"
                                                     BeginTime="0:0:0.3"
                                                     AutoReverse="True">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
            </StackPanel>

            <!-- Error -->
            <TextBlock Text="{Binding Error}" FontSize="12"
                       Foreground="{DynamicResource ErrorBrush}"
                       TextWrapping="Wrap"
                       Visibility="{Binding Error, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}" />

            <!-- Metric lines -->
            <ItemsControl ItemsSource="{Binding OverviewLines}"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}, FallbackValue=Visible}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:MetricLineControl Margin="0,0,0,10" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
