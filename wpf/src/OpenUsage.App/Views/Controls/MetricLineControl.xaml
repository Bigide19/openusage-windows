<UserControl x:Class="OpenUsage.App.Views.Controls.MetricLineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:OpenUsage.Core.Models;assembly=OpenUsage.Core">

    <UserControl.Resources>
        <!-- ═══ Progress line template ═══ -->
        <DataTemplate DataType="{x:Type core:ProgressMetricLine}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{Binding Label}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <Ellipse Width="7" Height="7" Margin="6,0,0,0" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <MultiBinding Converter="{StaticResource PaceDotColorConverter}">
                                <Binding Path="Used" />
                                <Binding Path="Limit" />
                            </MultiBinding>
                        </Ellipse.Fill>
                    </Ellipse>
                </StackPanel>

                <Border Background="{DynamicResource ProgressTrackBrush}"
                        CornerRadius="7" Height="14" Margin="0,0,0,4">
                    <Border CornerRadius="7" HorizontalAlignment="Left"
                            Background="{DynamicResource ProgressFillBrush}">
                        <Border.Width>
                            <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                <Binding Path="Used" />
                                <Binding Path="Limit" />
                                <Binding RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=2}" Path="ActualWidth" />
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Consolas">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ProgressFormatConverter}">
                                <Binding Path="Used" />
                                <Binding Path="Limit" />
                                <Binding Path="Format" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBlock Grid.Column="1" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Text="{Binding ResetsAt, Converter={StaticResource ResetTimeConverter}}" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- ═══ Text line template ═══ -->
        <DataTemplate DataType="{x:Type core:TextMetricLine}">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Label}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding Value}" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <!-- ═══ Badge line template ═══ -->
        <DataTemplate DataType="{x:Type core:BadgeMetricLine}">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Label}" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />

                <Border Grid.Column="1"
                        CornerRadius="10" Padding="6,2"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource TextSecondaryBrush}"
                        Background="Transparent"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Text}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <ContentPresenter Content="{Binding}" />
</UserControl>
