<UserControl x:Class="OpenUsage.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:OpenUsage.Core.Enums;assembly=OpenUsage.Core">

    <UserControl.Resources>
        <!-- Base toggle button style for radio-like selection groups -->
        <Style x:Key="ToggleOptionButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource AccentHighlightBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Wide toggle with subtitle text -->
        <Style x:Key="ToggleOptionWithSubtitle" TargetType="RadioButton" BasedOn="{StaticResource ToggleOptionButton}">
            <Setter Property="Padding" Value="12,10" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="12">
        <StackPanel>

            <!-- ═══ 1. Auto Refresh ═══ -->
            <TextBlock Text="Auto Refresh" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="How obsessive are you" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource MutedBackgroundBrush}"
                    CornerRadius="8" Padding="4">
                <UniformGrid Rows="1">
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="AutoRefresh"
                                 IsChecked="{Binding AutoUpdateInterval, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:AutoUpdateInterval.Minutes5}}"
                                 Content="5m" />
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="AutoRefresh"
                                 IsChecked="{Binding AutoUpdateInterval, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:AutoUpdateInterval.Minutes15}}"
                                 Content="15m" />
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="AutoRefresh"
                                 IsChecked="{Binding AutoUpdateInterval, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:AutoUpdateInterval.Minutes30}}"
                                 Content="30m" />
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="AutoRefresh"
                                 IsChecked="{Binding AutoUpdateInterval, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:AutoUpdateInterval.Minutes60}}"
                                 Content="1h" />
                </UniformGrid>
            </Border>

            <!-- Spacer -->
            <Border Height="24" />

            <!-- ═══ 2. Usage Mode ═══ -->
            <TextBlock Text="Usage Mode" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="Glass half full or half empty" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource MutedBackgroundBrush}"
                    CornerRadius="8" Padding="4">
                <UniformGrid Rows="1">
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="DisplayMode"
                                 IsChecked="{Binding DisplayMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:DisplayMode.Used}}"
                                 Content="Used" />
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="DisplayMode"
                                 IsChecked="{Binding DisplayMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:DisplayMode.Left}}"
                                 Content="Left" />
                </UniformGrid>
            </Border>

            <!-- Spacer -->
            <Border Height="24" />

            <!-- ═══ 3. Reset Timers ═══ -->
            <TextBlock Text="Reset Timers" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="Countdown or clock time" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource MutedBackgroundBrush}"
                    CornerRadius="8" Padding="4">
                <UniformGrid Rows="1">
                    <RadioButton Style="{StaticResource ToggleOptionWithSubtitle}"
                                 GroupName="ResetTimer"
                                 IsChecked="{Binding ResetTimerDisplayMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:ResetTimerDisplayMode.Relative}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Relative" FontSize="13" FontWeight="Medium"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="5h 12m" FontSize="10"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       Opacity="0.7"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource ToggleOptionWithSubtitle}"
                                 GroupName="ResetTimer"
                                 IsChecked="{Binding ResetTimerDisplayMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:ResetTimerDisplayMode.Absolute}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Absolute" FontSize="13" FontWeight="Medium"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="today at 11:04 AM" FontSize="10"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       Opacity="0.7"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </UniformGrid>
            </Border>

            <!-- Spacer -->
            <Border Height="24" />

            <!-- ═══ 4. App Theme ═══ -->
            <TextBlock Text="App Theme" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="How it looks around here" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource MutedBackgroundBrush}"
                    CornerRadius="8" Padding="4">
                <UniformGrid Rows="1">
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="Theme"
                                 IsChecked="{Binding ThemeMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:ThemeMode.Light}}"
                                 Content="Light" />
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="Theme"
                                 IsChecked="{Binding ThemeMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:ThemeMode.Dark}}"
                                 Content="Dark" />
                    <RadioButton Style="{StaticResource ToggleOptionButton}"
                                 GroupName="Theme"
                                 IsChecked="{Binding ThemeMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:ThemeMode.System}}"
                                 Content="System" />
                </UniformGrid>
            </Border>

            <!-- Spacer -->
            <Border Height="24" />

            <!-- ═══ 5. Start on Login ═══ -->
            <TextBlock Text="Start on Login" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="OpenUsage starts when you sign in" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource MutedBackgroundBrush}"
                    CornerRadius="8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Enable" FontSize="13"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding StartOnLogin}"
                              Style="{DynamicResource ToggleSwitchStyle}"
                              VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Spacer -->
            <Border Height="24" />

            <!-- ═══ 6. Plugins ═══ -->
            <TextBlock Text="Plugins" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,2" />
            <TextBlock Text="Your AI coding lineup" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,8" />

            <ItemsControl ItemsSource="{Binding PluginItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="PluginItemBorder"
                                Background="{DynamicResource MutedBackgroundBrush}"
                                CornerRadius="8" Padding="12,10" Margin="0,0,0,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding IsEnabled}"
                                          Style="{DynamicResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Bottom padding -->
            <Border Height="12" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
